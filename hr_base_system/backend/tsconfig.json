{
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@simpala/types": [
                "../../packages/types/dist"
            ],
            "@prisma/client": [
                "../../node_modules/@prisma/client"
            ],
            ".prisma/client": [
                "../../node_modules/.prisma/client"
            ],
            ".prisma/client/*": [
                "../../node_modules/.prisma/client/*"
            ]
        },
        "typeRoots": [
            "./node_modules/@types",
            "../../node_modules/@types"
        ],
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "skipLibCheck": true,
        "rootDir": "./",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "create-test-user.ts",
        "src/tests/**/*",
        "prisma/seeds/**/*",
        "src/__mocks__"
    ]
}