{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "npx prisma generate && tsc --noEmit",
    "build:production": "npx prisma generate --schema=./prisma/schema.prisma && tsc --noCheck",
    "build:seeds": "tsc prisma/seeds/e2e-user.seed.ts --outDir prisma/seeds --skipLibCheck --esModuleInterop --resolveJsonModule --module commonjs --target ES2020 --moduleResolution node && (mv prisma/seeds/e2e-user.seed.js prisma/seeds/e2e-user.seed.cjs 2>/dev/null || move prisma\\seeds\\e2e-user.seed.js prisma\\seeds\\e2e-user.seed.cjs 2>nul || true)",
    "start": "ts-node src/index.ts",
    "start:production": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --config jest.unit.config.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPatterns=integration\\.test\\.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "seed": "ts-node prisma/seeds/dev.seed.ts",
    "seed:test": "ts-node prisma/seeds/test.seed.ts",
    "seed:e2e-user": "node prisma/seeds/e2e-user.seed.cjs",
    "db:reset": "npx prisma migrate reset --force && npm run seed",
    "extract-ai-data": "ts-node src/scripts/extract_ai_data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "[![CI/CD](https://github.com/Mad-marketing-git/HR/actions/workflows/ci.yml/badge.svg)](https://github.com/Mad-marketing-git/HR/actions/workflows/ci.yml)",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@simpala/types": "1.0.0",
    "@simplewebauthn/server": "^13.2.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-winston": "^4.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.6",
    "multer": "1.4.5-lts.1",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.15.2",
    "pg": "^8.16.3",
    "prisma": "^6.19.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.7",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.48.0"
  }
}